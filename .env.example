# ── LLM provider ───────────────────────────────────────────────────
# Default provider — used by any role that does NOT have its own
# <ROLE>_PROVIDER override. "claude" or "gemini". Switching does NOT
# rewrite model IDs below — set them to values appropriate for whichever
# provider each role ends up resolving to.
LLM_PROVIDER=claude

# Claude (required when any role resolves to "claude")
ANTHROPIC_API_KEY=sk-ant-...

# Gemini (required when any role resolves to "gemini")
GOOGLE_API_KEY=

# ── Per-role provider overrides (optional) ─────────────────────────
# Leave unset to inherit LLM_PROVIDER. Set per-role to mix providers in
# a single generation, e.g. STRATEGIST_PROVIDER=claude (deeper reasoning)
# + BUILDER_PROVIDER=gemini (cheaper code generation). Whatever provider
# a role resolves to, the corresponding <ROLE>_MODEL below MUST be a
# model in that provider's namespace.
STRATEGIST_PROVIDER=gemini
PLAYER_PROVIDER=gemini
BUILDER_PROVIDER=gemini
ADVERSARY_PROVIDER=gemini

# ── Models ─────────────────────────────────────────────────────────
# Claude defaults:
# STRATEGIST_MODEL=claude-opus-4-6
# PLAYER_MODEL=claude-sonnet-4-6
# BUILDER_MODEL=claude-sonnet-4-6
# ADVERSARY_MODEL=claude-opus-4-6

# Gemini examples (uncomment + swap if you set the matching role to
# Gemini via LLM_PROVIDER or <ROLE>_PROVIDER above):
STRATEGIST_MODEL=gemini-3-flash
PLAYER_MODEL=gemini-3-flash
BUILDER_MODEL=gemini-3-flash
ADVERSARY_MODEL=gemini-3-flash

# ── Adversary chain ────────────────────────────────────────────────
# When true (default), every builder candidate is critiqued by the
# adversary and revised by the fixer before validation. Set to false
# to bypass the chain and validate builder output directly.
ENABLE_ADVERSARY=true

# ── Database ───────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./darwin.db

# ── Tournament defaults ────────────────────────────────────────────
TIME_PER_MOVE_MS=20000
GAMES_PER_PAIRING=2
MAX_PARALLEL_GAMES=2
MAX_MOVES_PER_GAME=120

# ── API ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000
